#!/usr/bin/env python3
"""Nautical command-line entry point."""

from __future__ import annotations

import runpy
import sys
from pathlib import Path


ROOT = Path(__file__).resolve().parent
COMMANDS = {
    "install": ROOT / "nautical_core" / "tools" / "nautical_install.py",
    "doctor": ROOT / "nautical_core" / "tools" / "nautical_doctor.py",
    "queue-status": ROOT / "nautical_core" / "tools" / "nautical_queue_status.py",
    "chain-repair": ROOT / "nautical_core" / "tools" / "nautical_chain_repair.py",
    "reconcile": ROOT / "nautical_core" / "tools" / "nautical_reconcile.py",
    "navigator": ROOT / "nautical_navigator.py",
}
ALIASES = {
    "queue": "queue-status",
    "repair": "chain-repair",
    "nav": "navigator",
}


def main() -> int:
    if len(sys.argv) < 2 or sys.argv[1] in {"-h", "--help"}:
        print("usage: nautical <command> [options]")
        print("commands: install, doctor, queue-status, chain-repair, reconcile, navigator")
        return 0
    command = ALIASES.get(sys.argv[1], sys.argv[1])
    target = COMMANDS.get(command)
    if target is None:
        print(f"nautical: unknown command '{sys.argv[1]}'", file=sys.stderr)
        return 2
    sys.argv = [str(target), *sys.argv[2:]]
    runpy.run_path(str(target), run_name="__main__")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
