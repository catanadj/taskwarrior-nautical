#!/usr/bin/env python3
"""Nautical command-line entry point."""

from __future__ import annotations

import runpy
import sys
from pathlib import Path


ROOT = Path(__file__).resolve().parent


def main() -> int:
    if len(sys.argv) < 2 or sys.argv[1] in {"-h", "--help"}:
        print("usage: nautical doctor [options]")
        return 0
    command = sys.argv[1]
    if command != "doctor":
        print(f"nautical: unknown command '{command}'", file=sys.stderr)
        return 2
    sys.argv = [f"{sys.argv[0]} doctor", *sys.argv[2:]]
    runpy.run_path(str(ROOT / "nautical_core" / "tools" / "nautical_doctor.py"), run_name="__main__")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
